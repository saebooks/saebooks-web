#: saebooks_web/eid_sso.py:94
msgid "You declined the sign-in request on your device."
msgstr "Keeldusid sisselogimisest oma seadmes."

#: saebooks_web/eid_sso.py:95 saebooks_web/eid_sso.py:221
msgid "The request expired before it was confirmed. Please try again."
msgstr "Päring aegus enne kinnitamist. Palun proovi uuesti."

#: saebooks_web/eid_sso.py:96
msgid "The wrong verification code was chosen. Please try again."
msgstr "Valiti vale kontrollkood. Palun proovi uuesti."

#: saebooks_web/eid_sso.py:97
msgid "No active Smart-ID or Mobiil-ID account was found for these details."
msgstr "Nende andmetega aktiivset Smart-ID või Mobiil-ID kontot ei leitud."

#: saebooks_web/eid_sso.py:98
msgid "The eID service is temporarily unavailable. Please try again shortly."
msgstr ""
"eID teenus ei ole ajutiselt kättesaadav. Palun proovi mõne hetke pärast "
"uuesti."

#: saebooks_web/eid_sso.py:99
msgid "The authentication response could not be verified."
msgstr "Autentimisvastust ei õnnestunud kontrollida."

#: saebooks_web/eid_sso.py:100
msgid "eID sign-in is not configured on this server."
msgstr "eID sisselogimine ei ole selles serveris seadistatud."

#: saebooks_web/eid_sso.py:101
msgid "eID sign-in failed. Please try again."
msgstr "eID sisselogimine ebaõnnestus. Palun proovi uuesti."

#: saebooks_web/eid_sso.py:173
msgid "That does not look like a valid Estonian personal code."
msgstr "See ei näi olevat kehtiv Eesti isikukood."

#: saebooks_web/eid_sso.py:214
msgid "This sign-in attempt has expired. Please start again."
msgstr "See sisselogimiskatse on aegunud. Palun alusta uuesti."

#: saebooks_web/eid_sso.py:272
msgid "Could not resolve your account email. Please re-login and retry."
msgstr ""
"Sinu konto e-posti aadressi ei õnnestunud tuvastada. Palun logi uuesti sisse"
" ja proovi uuesti."

#: saebooks_web/eid_sso.py:280
msgid "This personal code is already linked to a different account."
msgstr "See isikukood on juba seotud teise kontoga."

#: saebooks_web/eid_sso.py:316
msgid ""
"Your identity was verified, but no account is linked to this personal code "
"yet. Sign in with your password first, then link your eID under Settings."
msgstr ""
"Sinu isik on tuvastatud, kuid selle isikukoodiga ei ole veel kontot seotud. "
"Logi esmalt sisse parooliga ja seo oma eID seadete lehel."

#: saebooks_web/eid_sso.py:326
msgid "Sign-in failed on the server. Please try again."
msgstr "Sisselogimine ebaõnnestus serveris. Palun proovi uuesti."

#: saebooks_web/routes/companies.py:178
msgid "Registrikood is required for an Estonian company."
msgstr "Registrikood on vajalik Eesti ettevõttele."

#: saebooks_web/routes/companies.py:180
msgid "Registrikood must be exactly 8 digits."
msgstr "Registrikood peab olema täpselt 8 numbrit."

#: saebooks_web/routes/companies.py:182
msgid "KMV/VAT number must be \"EE\" followed by 9 digits, e.g. EE123456789."
msgstr ""
"KMV/VAT number peab olema \"EE\", millele järgneb 9 numbrit, nt EE123456789."

