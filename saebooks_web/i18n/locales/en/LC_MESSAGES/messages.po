#: saebooks_web/eid_sso.py:325
msgid "Sign-in failed on the server. Please try again."
msgstr "Sign-in failed on the server. Please try again."

#: saebooks_web/routes/companies.py:177
msgid "Registrikood is required for an Estonian company."
msgstr "Registrikood is required for an Estonian company."

#: saebooks_web/routes/companies.py:179
msgid "Registrikood must be exactly 8 digits."
msgstr "Registrikood must be exactly 8 digits."

#: saebooks_web/routes/companies.py:181
msgid "KMV/VAT number must be \"EE\" followed by 9 digits, e.g. EE123456789."
msgstr "KMV/VAT number must be \"EE\" followed by 9 digits, e.g. EE123456789."

#: saebooks_web/routes/companies.py:211
msgid "Company created. Estonian jurisdiction, registrikood and KMV/VAT number were captured but could not be saved yet — the engine does not accept these fields on company creation. This is tracked separately; the values above were not persisted."
msgstr "Company created. Estonian jurisdiction, registrikood and KMV/VAT number were captured but could not be saved yet — the engine does not accept these fields on company creation. This is tracked separately; the values above were not persisted."

