    {%- set _ = grouped.sections.update({sec: []}) -%}
  {%- endif -%}
  {%- set _ = grouped.sections[sec].append(ln) -%}
{%- endfor %}

{% for sec_label in grouped.order %}
{%- set sec_lines = grouped.sections[sec_label] %}

