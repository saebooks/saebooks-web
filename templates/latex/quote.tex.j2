{#
  quote.tex.j2 — SAE Engineering quote / estimate

  Context keys (all data values MUST be latex_escape'd before interpolation):
    number          str   quote number, e.g. "1019"
    title           str   project name
    scope           str   scope of works (may be multi-line)
    issue_date      str   ISO date "YYYY-MM-DD"
    expiry_date     str   ISO date "YYYY-MM-DD" or ""
    validity_days   int   e.g. 14
    deposit_pct     str   e.g. "50"
    subtotal        str   decimal string (ex GST)
    total           str   decimal string (inc GST)
    customer        dict  keys: name, contact, email, phone, mobile
    lines           list  dicts with:
                          line_no, description, quantity, line_total,
                          section_label, material, length_note, drawing_ref

  Design matches the existing ReportLab render_quote_pdf layout:
    letterhead → blue rule → ESTIMATE / SAE-2026-{number}
    → info boxes (Estimate To / Estimate Details)
    → Project Details box
    → sections grouped by section_label (heading + booktabs table)
    → Total bar
    → Key Terms / Insurance & Licences / Bank Details / Acceptance

  Fonts: Liberation Sans (confirmed present in latex-api TexLive image).
  Colours: saeblue #1B3A5C, saegrey #4A4A4A, ltgrey #F2F2F2, accent #E8792B.
  NO TeX Gyre Heros — it is not installed in latex-api.

  Bare % in .tex source = LaTeX comment — every literal percent MUST
  come from |latex_escape which renders it as \%.
#}
{%- macro fmt_money(v) -%}
  {%- if v is not none -%}\${{ "%.2f"|format(v|float) }}{%- else -%}\$0.00{%- endif -%}
{%- endmacro -%}
{%- macro fmt_qty(v) -%}
  {%- if v is not none and v != "" -%}
    {%- set d = v|float -%}
    {%- if d == d|int|float -%}{{ d|int }}{%- else -%}{{ "%.2f"|format(d) }}{%- endif -%}
  {%- endif -%}
{%- endmacro -%}
{%- macro fmt_date(iso) -%}
  {%- if iso and iso|length >= 10 -%}
    {%- set parts = iso[:10].split('-') -%}
    {%- set months = ["January","February","March","April","May","June","July","August","September","October","November","December"] -%}
    {{ parts[2]|int }} {{ months[parts[1]|int - 1] }} {{ parts[0] }}
  {%- else -%}---{%- endif -%}
{%- endmacro -%}
{%- set ns = namespace(has_material=false, has_length=false, has_drawing=false) -%}
