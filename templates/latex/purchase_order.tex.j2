{#
  purchase_order.tex.j2 — SAE Engineering purchase order

  Context keys (all data values MUST be latex_escape'd before interpolation):
    number          str   PO number, e.g. "PO-000001"
    issue_date      str   ISO date "YYYY-MM-DD"
    expected_date   str   ISO date "YYYY-MM-DD" or ""
    currency        str   e.g. "AUD"
    subtotal        str   decimal string (ex GST)
    tax_total       str   decimal string (GST)
    total           str   decimal string (inc GST)
    notes           str   free text, omit section if empty
    supplier        dict  keys: name, contact, email, phone
    delivery_lines  list  of str — delivery address split into lines
    lines           list  dicts with: line_no, description, quantity,
                          unit_price, line_subtotal, line_tax
    logo_path       str|None  absolute path (inside latex-api) to the
                          letterhead logo PNG; injected by render_latex
                          from LATEX_LOGO_PATH. None → text letterhead.

  Letterhead/colours/fonts match quote.tex.j2 (Liberation Sans;
  saeblue #1B3A5C, saegrey #4A4A4A, ltgrey #F2F2F2, accent #E8792B).

  Bare % in .tex source = LaTeX comment — every literal percent MUST
  come from |latex_escape which renders it as \%.
#}
{%- macro fmt_money(v) -%}
  {%- if v is not none -%}\${{ "%.2f"|format(v|float) }}{%- else -%}\$0.00{%- endif -%}
{%- endmacro -%}
{%- macro fmt_qty(v) -%}
  {%- if v is not none and v != "" -%}
    {%- set d = v|float -%}
    {%- if d == d|int|float -%}{{ d|int }}{%- else -%}{{ "%.2f"|format(d) }}{%- endif -%}
  {%- endif -%}
{%- endmacro -%}
{%- macro fmt_date(iso) -%}
  {%- if iso and iso|length >= 10 -%}
    {%- set parts = iso[:10].split('-') -%}
    {%- set months = ["January","February","March","April","May","June","July","August","September","October","November","December"] -%}
    {{ parts[2]|int }} {{ months[parts[1]|int - 1] }} {{ parts[0] }}
  {%- else -%}---{%- endif -%}
{%- endmacro -%}
